@{
    ViewBag.Title = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-0">Welcome, <span class="text-primary">@ViewBag.Username</span> 👋</h2>
                    <p class="text-muted mb-0">Library Management Dashboard</p>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-primary btn-sm" id="refreshData">
                        <i class="bi bi-arrow-clockwise"></i> Refresh
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Cards -->
    <div class="row g-4 mb-5" id="statsCards">
        <div class="col-md-3">
            <div class="card text-white bg-primary shadow-sm h-100 stats-card" data-bs-toggle="tooltip"
                 data-bs-placement="top" title="Total books in library">
                <div class="card-body position-relative">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title opacity-75">Total Books</h6>
                            <h3 class="card-text mb-0" id="totalBooks">
                                <div class="spinner-border spinner-border-sm" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                            </h3>
                        </div>
                        <i class="bi bi-book fs-1 opacity-50"></i>
                    </div>
                    <div class="progress mt-2" style="height: 4px;">
                        <div class="progress-bar bg-white" role="progressbar" style="width: 0%" id="totalBooksProgress"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-white bg-success shadow-sm h-100 stats-card" data-bs-toggle="tooltip"
                 data-bs-placement="top" title="Books available for issue">
                <div class="card-body position-relative">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title opacity-75">Available Books</h6>
                            <h3 class="card-text mb-0" id="availableBooks">
                                <div class="spinner-border spinner-border-sm" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                            </h3>
                        </div>
                        <i class="bi bi-journal-arrow-down fs-1 opacity-50"></i>
                    </div>
                    <div class="progress mt-2" style="height: 4px;">
                        <div class="progress-bar bg-white" role="progressbar" style="width: 0%" id="availableBooksProgress"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-white bg-warning shadow-sm h-100 stats-card" data-bs-toggle="tooltip"
                 data-bs-placement="top" title="Books currently issued">
                <div class="card-body position-relative">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title opacity-75">Issued Books</h6>
                            <h3 class="card-text mb-0" id="issuedBooks">
                                <div class="spinner-border spinner-border-sm" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                            </h3>
                        </div>
                        <i class="bi bi-arrow-left-right fs-1 opacity-50"></i>
                    </div>
                    <div class="progress mt-2" style="height: 4px;">
                        <div class="progress-bar bg-white" role="progressbar" style="width: 0%" id="issuedBooksProgress"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-white bg-danger shadow-sm h-100 stats-card" data-bs-toggle="tooltip"
                 data-bs-placement="top" title="Books overdue for return">
                <div class="card-body position-relative">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title opacity-75">Overdue</h6>
                            <h3 class="card-text mb-0" id="overdueBooks">
                                <div class="spinner-border spinner-border-sm" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                            </h3>
                        </div>
                        <i class="bi bi-exclamation-circle fs-1 opacity-50"></i>
                    </div>
                    <div class="progress mt-2" style="height: 4px;">
                        <div class="progress-bar bg-white" role="progressbar" style="width: 0%" id="overdueBooksProgress"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Section -->
    <div class="row mb-5">
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Books Issued Trend</h5>
                    <div class="spinner-border spinner-border-sm d-none" role="status" id="chartLoader1">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
                <div class="card-body">
                    <canvas id="barChart" height="200"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Books by Category</h5>
                    <div class="spinner-border spinner-border-sm d-none" role="status" id="chartLoader2">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
                <div class="card-body">
                    <canvas id="pieChart" height="200"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Book Distribution by Category</h5>
                    <div class="input-group" style="width: 250px;">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control form-control-sm" placeholder="Search categories..."
                               id="categorySearch">
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0" id="categoryTable">
                            <thead class="table-secondary">
                                <tr>
                                    <th>Category</th>
                                    <th class="text-end">Books Issued</th>
                                    <th class="text-end">Total Books</th>
                                    <th class="text-end">Percentage</th>
                                    <th class="text-center">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="categoryTableBody">
                                <!-- Loading state -->
                                <tr id="categoryTableLoader">
                                    <td colspan="5" class="text-center py-4">
                                        <div class="spinner-border" role="status">
                                            <span class="visually-hidden">Loading...</span>
                                        </div>
                                        <div class="mt-2">Loading categories...</div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">⚡ Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a href="@Url.Action("Index", "Book")" class="btn btn-outline-primary btn-lg">
                            <i class="bi bi-book me-2"></i> Manage Books
                        </a>
                        <a href="@Url.Action("Index", "Member")" class="btn btn-outline-success btn-lg">
                            <i class="bi bi-people me-2"></i> View Members
                        </a>
                        <a href="@Url.Action("OverdueBooks", "Report")" class="btn btn-outline-warning btn-lg">
                            <i class="bi bi-arrow-left-right me-2"></i> Over Due Books
                        </a>
                        <a href="@Url.Action("BookList", "Report")" class="btn btn-outline-info btn-lg">
                            <i class="bi bi-graph-up me-2"></i> Book History
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="toast-container position-fixed top-0 end-0 p-3">
    <div id="notificationToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="toast-header">
            <i class="bi bi-bell-fill me-2 text-primary"></i>
            <strong class="me-auto">Notification</strong>
            <small class="text-muted">now</small>
            <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
        <div class="toast-body" id="toastMessage">
        </div>
    </div>
</div>

@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        let barChart, pieChart;
        let currentTimeRange = 7;

        // Initialize dashboard
        $(document).ready(function() {
            initializeDashboard();
            initializeTooltips();
            setupEventHandlers();
            loadDashboardData();
        });

        function initializeDashboard() {
            const barCtx = document.getElementById('barChart').getContext('2d');
            const pieCtx = document.getElementById('pieChart').getContext('2d');

            barChart = new Chart(barCtx, {
                type: 'bar',
                data: {
                    labels: [],
                    datasets: [{
                        label: 'Books Issued',
                        data: [],
                        backgroundColor: 'rgba(54, 162, 235, 0.7)',
                        borderColor: 'rgba(54, 162, 235, 1)',
                        borderWidth: 1,
                        borderRadius: 4,
                        borderSkipped: false,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: true,
                            position: 'top'
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                stepSize: 1
                            }
                        }
                    },
                    animation: {
                        duration: 1000,
                        easing: 'easeInOutQuart'
                    }
                }
            });

            pieChart = new Chart(pieCtx, {
                type: 'doughnut',
                data: {
                    labels: [],
                    datasets: [{
                        data: [],
                        backgroundColor: [
                            '#007bff', '#28a745', '#ffc107', '#dc3545', '#17a2b8',
                            '#6f42c1', '#fd7e14', '#20c997', '#6c757d', '#e83e8c'
                        ],
                        borderWidth: 2,
                        borderColor: '#fff'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                padding: 20,
                                usePointStyle: true
                            }
                        }
                    },
                    animation: {
                        duration: 1000,
                        easing: 'easeInOutQuart'
                    }
                }
            });
        }

        function initializeTooltips() {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            var tooltipList = tooltipTriggerList.map(function(tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });
        }

        function setupEventHandlers() {
            $('#refreshData').on('click', function() {
                $(this).prop('disabled', true);
                loadDashboardData();
                setTimeout(() => {
                    $(this).prop('disabled', false);
                }, 2000);
            });

            $('.dropdown-item[data-range]').on('click', function(e) {
                e.preventDefault();
                currentTimeRange = parseInt($(this).data('range'));
                $('#timeRangeDropdown').text($(this).text());
                loadDashboardData();
            });

            // Category search
            $('#categorySearch').on('input', function() {
                const searchTerm = $(this).val().toLowerCase();
                $('#categoryTableBody tr').each(function() {
                    const categoryName = $(this).find('td:first').text().toLowerCase();
                    $(this).toggle(categoryName.includes(searchTerm));
                });
            });

            // Refresh activity
            $('#refreshActivity').on('click', function() {
                loadRecentActivity();
            });

            $('.stats-card').on('mouseenter', function() {
                $(this).addClass('shadow-lg');
            }).on('mouseleave', function() {
                $(this).removeClass('shadow-lg');
            });
        }

        function loadDashboardData() {
            showToast('Loading dashboard data...', 'info');

            $.ajax({
                url: '@Url.Action("GetDashboardData", "Dashboard")',
                type: 'GET',
                data: { timeRange: currentTimeRange },
                success: function(data) {
                    updateStatsCards(data.stats);
                    updateCharts(data.charts);
                    updateCategoryTable(data.categories);
                    loadRecentActivity();
                    showToast('Dashboard updated successfully!', 'success');
                },
                error: function() {
                    loadFallbackData();
                    showToast('Using cached data - some features may be limited', 'warning');
                }
            });
        }

        function loadFallbackData() {
            const stats = {
                totalBooks: 150,
                availableBooks: 120,
                issuedBooks: 30,
                overdueBooks: 5
            };

            updateStatsCards(stats);

            // Update charts with ViewBag data
            barChart.data.labels = @Html.Raw(Json.Encode(ViewBag.Last7DaysLabels ?? new string[] {"Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"}));
            barChart.data.datasets[0].data = @Html.Raw(Json.Encode(ViewBag.Last7DaysData ?? new int[] {5, 8, 12, 7, 15, 10, 6}));
            barChart.update();

            pieChart.data.labels = @Html.Raw(Json.Encode(ViewBag.Categories ?? new string[] {"Fiction", "Non-Fiction", "Science", "History", "Biography"}));
            pieChart.data.datasets[0].data = @Html.Raw(Json.Encode(ViewBag.CategoryData ?? new int[] {25, 20, 15, 10, 8}));
            pieChart.update();

            // Update category table
            const categories = @Html.Raw(Json.Encode(ViewBag.Categories ?? new string[] {"Fiction", "Non-Fiction", "Science", "History", "Biography"}));
            const categoryData = @Html.Raw(Json.Encode(ViewBag.CategoryData ?? new int[] {25, 20, 15, 10, 8}));

            const categoryTableData = [];
            for (let i = 0; i < categories.length; i++) {
                categoryTableData.push({
                    name: categories[i],
                    issued: categoryData[i],
                    total: categoryData[i] + Math.floor(Math.random() * 20) + 10,
                    percentage: ((categoryData[i] / 78) * 100).toFixed(1)
                });
            }

            updateCategoryTable(categoryTableData);
            loadRecentActivity();
        }

        function updateStatsCards(stats) {
            // Animate number updates
            animateNumber('#totalBooks', stats.TotalBooks);
            animateNumber('#availableBooks', stats.AvailableBooks);
            animateNumber('#issuedBooks', stats.IssuedBooks);
            animateNumber('#overdueBooks', stats.OverdueBooks);

            // Update progress bars
            setTimeout(() => {
                $('#totalBooksProgress').css('width', '100%');
                $('#availableBooksProgress').css('width', `${(stats.AvailableBooks / stats.TotalBooks) * 100}%`);
                $('#issuedBooksProgress').css('width', `${(stats.IssuedBooks / stats.TotalBooks) * 100}%`);
                $('#overdueBooksProgress').css('width', `${(stats.OverdueBooks / stats.IssuedBooks) * 100}%`);
            }, 500);
        }

        function animateNumber(selector, targetNumber) {
            const element = $(selector);
            const startNumber = 0;
            const duration = 1000;
            const startTime = Date.now();

            function updateNumber() {
                const elapsed = Date.now() - startTime;
                const progress = Math.min(elapsed / duration, 1);
                const currentNumber = Math.floor(startNumber + (targetNumber - startNumber) * progress);

                element.text(currentNumber);

                if (progress < 1) {
                    requestAnimationFrame(updateNumber);
                }
            }

            updateNumber();
        }

        function updateCharts(chartData) {
            $('#chartLoader1, #chartLoader2').removeClass('d-none');

            setTimeout(() => {
                // --------------
                //  Bar Chart
                // --------------
                const weekDays = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"];
                const barLabels = [];
                const barValues = [];

                weekDays.forEach(day => {
                    barLabels.push(day);
                    barValues.push(chartData.bar?.[day] ?? 0);
                });

                const hasBarData = barValues.some(val => val > 0);

                if (hasBarData) {
                    barChart.data.labels = barLabels;
                    barChart.data.datasets[0].data = barValues;
                    barChart.data.datasets[0].backgroundColor = 'rgba(54, 162, 235, 0.7)';
                } else {
                    barChart.data.labels = ["No Data"];
                    barChart.data.datasets[0].data = [0];
                    barChart.data.datasets[0].backgroundColor = 'rgba(200, 200, 200, 0.6)';
                }

                barChart.update();

                // --------------
                //  Pie Chart
                // --------------
                const pieLabels = chartData.pie?.map(p => p.label) || [];
                const pieValues = chartData.pie?.map(p => p.value) || [];
                const hasPieData = pieValues.some(v => v > 0);

                if (hasPieData) {
                    pieChart.data.labels = pieLabels;
                    pieChart.data.datasets[0].data = pieValues;
                    pieChart.data.datasets[0].backgroundColor = generateRandomColors(pieLabels.length);
                } else {
                    pieChart.data.labels = ["No Data"];
                    pieChart.data.datasets[0].data = [0];
                    pieChart.data.datasets[0].backgroundColor = ['#cccccc'];
                }

                pieChart.update();

                $('#chartLoader1, #chartLoader2').addClass('d-none');
            }, 1000);
        }

        function generateRandomColors(count) {
            const colors = [];
            for (let i = 0; i < count; i++) {
                const r = Math.floor(Math.random() * 156) + 100;
                const g = Math.floor(Math.random() * 156) + 100;
                const b = Math.floor(Math.random() * 156) + 100;
                colors.push(`rgba(${r}, ${g}, ${b}, 0.7)`);
            }
            return colors;
        }

        function updateCategoryTable(categories) {
            const tbody = $('#categoryTableBody');
            tbody.empty();

            categories.forEach(category => {
                const row = `
                    <tr>
                        <td><strong>${category.Category}</strong></td>
                        <td class="text-end">${category.BooksIssued}</td>
                        <td class="text-end">${category.TotalBooks}</td>
                        <td class="text-end">
                            <div class="d-flex align-items-center justify-content-end">
                                <div class="progress me-2" style="width: 60px; height: 8px;">
                                    <div class="progress-bar" role="progressbar" style="width: ${category.Percentage}%"></div>
                                </div>
                                <span class="small">${category.Percentage}%</span>
                            </div>
                        </td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-outline-primary" onclick="viewCategoryDetails('${category.Category}')">
                                <i class="bi bi-eye"></i>
                            </button>
                        </td>
                    </tr>
                `;
                tbody.append(row);
            });
        }

        function loadRecentActivity() {
            const activityContainer = $('#recentActivity');

            setTimeout(() => {
                const activities = [
                    { icon: 'bi-book', text: 'New book "The Great Gatsby" added', time: '2 minutes ago', type: 'success' },
                    { icon: 'bi-person-plus', text: 'New member John Doe registered', time: '15 minutes ago', type: 'info' },
                    { icon: 'bi-arrow-left-right', text: 'Book returned by Jane Smith', time: '1 hour ago', type: 'warning' },
                    { icon: 'bi-exclamation-triangle', text: 'Book overdue reminder sent', time: '2 hours ago', type: 'danger' }
                ];

                activityContainer.empty();

                activities.forEach(activity => {
                    const item = `
                        <div class="list-group-item border-0 px-3 py-2">
                            <div class="d-flex align-items-center">
                                <div class="me-2">
                                    <i class="${activity.icon} text-${activity.type}"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="small mb-1">${activity.text}</div>
                                    <div class="text-muted" style="font-size: 0.75rem;">${activity.time}</div>
                                </div>
                            </div>
                        </div>
                    `;
                    activityContainer.append(item);
                });
            }, 1000);
        }

        function viewCategoryDetails(categoryName) {
            showToast(`Loading details for ${categoryName}...`, 'info');
        }

        function showToast(message, type = 'info') {
            const toastElement = $('#notificationToast');
            const toastBody = $('#toastMessage');

            // Update toast content
            toastBody.text(message);

            toastElement.removeClass('text-bg-success text-bg-warning text-bg-danger text-bg-info');
            toastElement.addClass(`text-bg-${type}`);

            // Show toast
            const toast = new bootstrap.Toast(toastElement[0]);
            toast.show();
        }

    </script>
}