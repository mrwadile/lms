@model Library.Core.Models.Member

@{
    ViewBag.Title = "Member Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Member Details</h3>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <strong>Full Name:</strong>
                            <p>@Model.FullName</p>
                        </div>
                        <div class="col-md-6">
                            <strong>Mobile:</strong>
                            <p>@Model.Mobile</p>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <strong>Email:</strong>
                            <p>@Model.Email</p>
                        </div>
                        <div class="col-md-6">
                            <strong>IsActive:</strong>
                            <p><span class="badge bg-info">@Model.IsActive</span></p>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <a href="@Url.Action("Edit", new { id = Model.MemberId })" class="btn btn-warning">Edit</a>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">Back to List</a>
                </div>
            </div>
        </div>
    </div>
</div>