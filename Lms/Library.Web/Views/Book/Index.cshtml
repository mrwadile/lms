@model IEnumerable<Library.Core.Models.Book>

@{
    ViewBag.Title = "Books";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary">Book List</h2>
        @Html.ActionLink("➕ Add New Book", "Create", null, new { @class = "btn btn-success" })
    </div>

    <!-- Search Section -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-md-8">
                    <input type="text" class="form-control" id="searchBooks" placeholder="Search by book title...">
                </div>
                <div class="col-md-4">
                    <button class="btn btn-outline-secondary" id="clearSearch">Clear</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Books Table -->
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped mb-0" id="booksTable">
                    <thead class="table-dark">
                        <tr>
                            <th>Title</th>
                            <th>Author</th>
                            <th>ISBN</th>
                            <th>Category</th>
                            <th>Total Copies</th>
                            <th>Available</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="booksTableBody">
                        @foreach (var item in Model)
                        {
                            <tr class="book-row">
                                <td class="book-title">
                                    <strong>@item.Title</strong>
                                </td>
                                <td>@item.Author</td>
                                <td>@item.ISBN</td>
                                <td>
                                    <span class="badge bg-info">@item.Category</span>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-secondary">@item.TotalCopies</span>
                                </td>
                                <td class="text-center">
                                    @if (item.AvailableCopies > 5)
                                    {
                                        <span class="badge bg-success">@item.AvailableCopies</span>
                                    }
                                    else if (item.AvailableCopies > 0)
                                    {
                                        <span class="badge bg-warning">@item.AvailableCopies</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">@item.AvailableCopies</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-sm btn-info text-white me-1 view-details-btn" data-id="@item.BookId">Details</button>
                                        <a href="@Url.Action("Edit", new { id = item.BookId })" class="btn btn-outline-warning" title="Edit">Edit</a>
                                        <button class="btn btn-outline-danger delete-btn" data-id="@item.BookId" title="Delete">Delete</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- No Results Message -->
        <div id="noResults" class="card-body text-center py-4" style="display: none;">
            <p class="text-muted">No books found matching your search.</p>
        </div>
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            // Search functionality
            $('#searchBooks').on('input', function () {
                const searchTerm = $(this).val().toLowerCase();
                filterBooks(searchTerm);
            });

            // Clear search
            $('#clearSearch').on('click', function () {
                $('#searchBooks').val('');
                filterBooks('');
            });

            // Filter books function
            function filterBooks(searchTerm) {
                const rows = $('.book-row');
                let visibleCount = 0;

                rows.each(function () {
                    const bookTitle = $(this).find('.book-title strong').text().toLowerCase();

                    if (searchTerm === '' || bookTitle.includes(searchTerm)) {
                        $(this).show();
                        visibleCount++;
                    } else {
                        $(this).hide();
                    }
                });

                // Show/hide no results message
                if (visibleCount === 0 && searchTerm !== '') {
                    $('#noResults').show();
                    $('#booksTable').hide();
                } else {
                    $('#noResults').hide();
                    $('#booksTable').show();
                }
            }

            $(document).on('click', '.view-details-btn', function (e) {
                e.preventDefault();
                const bookId = $(this).data('id');
                const url = '@Url.Action("Details", "Book")' + '/' + bookId;
                window.location.href = url;
            });

            $(document).on('click', '.delete-btn', function (e) {
                e.preventDefault();
                const bookId = $(this).data('id');
                const row = $(this).closest('tr');

                if (confirm('Are you sure you want to delete this book?')) {
                    $.ajax({
                        type: 'POST',
                        url: '@Url.Action("Delete", "Book")',
                        data: { id: bookId },
                        success: function (result) {
                            if (result.success) {
                                row.fadeOut(300, function () {
                                    $(this).remove();
                                });
                                alert('Book deleted successfully!');
                            } else {
                                alert(result.message || 'Failed to delete book.');
                            }
                        },
                        error: function () {
                            alert('An error occurred while deleting the book.');
                        }
                    });
                }
            });
        });
    </script>
}