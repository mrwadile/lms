@model Library.Core.Models.Book
@{
    ViewBag.Title = "Delete Book";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <!-- Header Section -->
            <div class="card border-0 shadow-lg mb-4">
                <div class="card-header bg-danger text-white text-center py-4">
                    <div class="d-flex align-items-center justify-content-center">
                        <i class="fas fa-trash-alt fa-2x me-3"></i>
                        <div>
                            <h2 class="mb-0 fw-bold">Delete Book</h2>
                            <p class="mb-0 opacity-75">This action cannot be undone</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Alert Messages -->
            <div id="resultMsg" class="alert alert-dismissible fade" role="alert" style="display: none;">
                <div class="d-flex align-items-center">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    <span id="alertMessage"></span>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>

            <div class="card border-0 shadow-lg">
                <div class="card-header bg-light border-bottom">
                    <div class="d-flex align-items-center">
                        <i class="fas fa-book text-primary me-2"></i>
                        <h4 class="mb-0 text-dark">Book Details</h4>
                    </div>
                </div>
                <div class="card-body p-4">
                    <div class="row">
                        <div class="col-md-3 text-center mb-4">
                            <div class="book-cover-placeholder bg-gradient-primary text-white rounded shadow d-flex align-items-center justify-content-center" style="height: 200px; width: 140px; margin: 0 auto;">
                                <i class="fas fa-book fa-3x opacity-75"></i>
                            </div>
                        </div>

                        <div class="col-md-9">
                            <div class="row g-3">
                                <div class="col-sm-6">
                                    <div class="info-item">
                                        <label class="form-label text-muted small fw-bold">
                                            <i class="fas fa-heading me-1"></i>
                                            @Html.DisplayNameFor(model => model.Title)
                                        </label>
                                        <p class="h5 text-dark mb-0">@Html.DisplayFor(model => model.Title)</p>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="info-item">
                                        <label class="form-label text-muted small fw-bold">
                                            <i class="fas fa-user-edit me-1"></i>
                                            @Html.DisplayNameFor(model => model.Author)
                                        </label>
                                        <p class="h6 text-dark mb-0">@Html.DisplayFor(model => model.Author)</p>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="info-item">
                                        <label class="form-label text-muted small fw-bold">
                                            <i class="fas fa-barcode me-1"></i>
                                            @Html.DisplayNameFor(model => model.ISBN)
                                        </label>
                                        <p class="text-dark mb-0 font-monospace">@Html.DisplayFor(model => model.ISBN)</p>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="info-item">
                                        <label class="form-label text-muted small fw-bold">
                                            <i class="fas fa-tags me-1"></i>
                                            @Html.DisplayNameFor(model => model.Category)
                                        </label>
                                        <p class="text-dark mb-0">
                                            <span class="badge bg-secondary rounded-pill">@Html.DisplayFor(model => model.Category)</span>
                                        </p>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="info-item">
                                        <label class="form-label text-muted small fw-bold">
                                            <i class="fas fa-copy me-1"></i>
                                            @Html.DisplayNameFor(model => model.TotalCopies)
                                        </label>
                                        <p class="text-dark mb-0">
                                            <span class="badge bg-info rounded-pill">@Html.DisplayFor(model => model.TotalCopies)</span>
                                        </p>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="info-item">
                                        <label class="form-label text-muted small fw-bold">
                                            <i class="fas fa-check-circle me-1"></i>
                                            @Html.DisplayNameFor(model => model.AvailableCopies)
                                        </label>
                                        <p class="text-dark mb-0">
                                            <span class="badge bg-success rounded-pill">@Html.DisplayFor(model => model.AvailableCopies)</span>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-warning shadow-sm mt-4">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <i class="fas fa-exclamation-triangle text-warning fa-2x"></i>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-warning mb-1">Warning!</h6>
                            <p class="text-muted mb-0">Are you absolutely sure you want to delete this book? This action cannot be undone and will permanently remove all associated data.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div id="editMemberForm" autocomplete="off" novalidate>
                @Html.AntiForgeryToken()
                @Html.HiddenFor(model => model.BookId)

                <div class="card border-0 shadow-sm mt-4">
                    <div class="card-body p-4">
                        <div class="d-flex flex-column flex-md-row gap-3 justify-content-center">
                            <button type="submit" class="btn btn-danger btn-lg px-5 shadow-sm" id="deleteBtn">
                                <span class="btn-content">
                                    <i class="fas fa-trash-alt me-2"></i>
                                    Yes, Delete Book
                                </span>
                                <span class="spinner-border spinner-border-sm me-2 d-none" id="deleteSpinner"></span>
                                <span class="d-none" id="deleteText">Deleting...</span>
                            </button>
                            @Html.ActionLink("Cancel", "Index", null, new { @class = "btn btn-outline-secondary btn-lg px-5 shadow-sm" })
                        </div>
                        <div class="text-center mt-3">
                            <small class="text-muted">
                                <i class="fas fa-info-circle me-1"></i>
                                You can also press ESC to cancel
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        $(function () {
            // ESC key to cancel
            $(document).keyup(function(e) {
                if (e.keyCode === 27) {
                    window.location.href = '@Url.Action("Index", "Book")';
                }
            });

            $('#deleteBookForm').submit(function (e) {
                e.preventDefault();

                if (confirm('Are you sure you want to delete this book?')) {
                    const $btn = $('#deleteBtn');
                    const $spinner = $('#deleteSpinner');
                    const $btnContent = $('.btn-content');
                    const $deleteText = $('#deleteText');

                    $btn.prop('disabled', true);
                    $btnContent.addClass('d-none');
                    $spinner.removeClass('d-none');
                    $deleteText.removeClass('d-none');

                    $.ajax({
                        type: 'POST',
                        url: '@Url.Action("Delete", "Book")',
                        data: $(this).serialize(),
                        success: function (result) {
                            if (result.success) {
                                showAlert('success', 'Book deleted successfully! Redirecting...', 'fas fa-check-circle');
                                setTimeout(function() {
                                    window.location.href = result.redirectUrl;
                                }, 1500);
                            } else {
                                showAlert('danger', 'Failed to delete book. ' + (result.message || 'Please try again.'), 'fas fa-exclamation-triangle');
                                resetButton();
                            }
                        },
                        error: function (xhr) {
                            showAlert('danger', 'Server error occurred. Please try again later.', 'fas fa-times-circle');
                            resetButton();
                            console.error(xhr.responseText);
                        }
                    });
                }
            });

            function showAlert(type, message, icon) {
                const $alert = $('#resultMsg');
                const $alertMessage = $('#alertMessage');

                $alert.removeClass('alert-success alert-danger alert-warning alert-info')
                      .addClass(`alert-${type}`)
                      .find('i').removeClass().addClass(`${icon} me-2`);

                $alertMessage.text(message);
                $alert.fadeIn().addClass('show');

                if (type !== 'success') {
                    setTimeout(function() {
                        $alert.fadeOut();
                    }, 5000);
                }
            }

            function resetButton() {
                const $btn = $('#deleteBtn');
                const $spinner = $('#deleteSpinner');
                const $btnContent = $('.btn-content');
                const $deleteText = $('#deleteText');

                $btn.prop('disabled', false);
                $btnContent.removeClass('d-none');
                $spinner.addClass('d-none');
                $deleteText.addClass('d-none');
            }
        });
    </script>
}