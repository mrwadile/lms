@model Library.Web.ViewModels.BookReturnViewModel

@{
    ViewBag.Title = "Return Book";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="card shadow-sm">
        <div class="card-header bg-warning text-dark">
            <h4><i class="fas fa-undo me-2"></i> Return a Book</h4>
        </div>
        <div class="card-body">
            <form id="returnForm" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-4">
                    <label for="IssueId" class="form-label fw-bold text-dark">
                        <i class="fas fa-book-reader me-2 text-primary"></i> Select Issued Book
                    </label>
                    @Html.DropDownList("IssueId",
                        new SelectList(Model.IssuedBooks, "IssueId", "DisplayText"),
                        "Select issued book",
                        new { @class = "form-select form-select-lg", required = "required" })
                </div>

                <div class="d-flex justify-content-between align-items-center">
                    <button type="submit" class="btn btn-danger btn-lg shadow-sm">
                        <i class="fas fa-undo me-2"></i> Return Book
                    </button>
                    <a href="@Url.Action("Index", "Book")" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left me-1"></i> Back to List
                    </a>
                </div>

                <div class="mt-3">
                    <span class="text-success fw-semibold" id="returnMessage" style="display:none;"></span>
                </div>
            </form>
        </div>
    </div>
</div>

@section scripts {
    <script>
        $('#returnForm').submit(function (e) {
            e.preventDefault();

            $.post('@Url.Action("Return", "BookIssue")', $(this).serialize(), function (res) {
                if (res.success) {
                    $('#returnMessage').text(res.message).fadeIn();
                    setTimeout(() => location.reload(), 1500);
                } else {
                    alert(res.message || "Something went wrong while returning the book.");
                }
            });
        });
    </script>
}
