<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title Library Management Portal</title>

    <link rel="icon" href="~/favicon.ico" type="image/x-icon" />
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")

    <style>
        body {
            background-color: #f8f9fa;
        }

        .navbar-brand {
            font-weight: bold;
            color: #ffc107 !important;
        }

        footer {
            padding: 20px 0;
            background-color: #212529;
            color: #ccc;
            text-align: center;
            margin-top: 40px;
        }
    </style>
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-sm navbar-dark bg-dark shadow-sm">
        <div class="container">
            @Html.ActionLink("LMS Lite", "Index", "Dashboard", null, new { @class = "navbar-brand" })

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        @Html.ActionLink("Dashboard", "Index", "Dashboard", null, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Books", "Index", "Book", null, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        @Html.ActionLink("Members", "Index", "Member", null, new { @class = "nav-link" })
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Issue", "BookIssue")">
                            <i class="fas fa-arrow-circle-right me-2"></i> Issue Book
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Return", "BookIssue")">
                            <i class="fas fa-undo-alt me-2"></i> Return Book
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="reportDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fas fa-chart-bar me-1"></i> Reports
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="reportDropdown">
                            <li>
                                <a class="dropdown-item" href="@Url.Action("OverdueBooks", "Report")">
                                    <i class="fas fa-exclamation-circle text-danger me-2"></i> Overdue Members
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="@Url.Action("BookList", "Report")">
                                    <i class="fas fa-book text-primary me-2"></i> Book History
                                </a>
                            </li>
                        </ul>
                    </li>

                </ul>

                @if (Session["UserId"] != null)
                {
                    <span class="navbar-text me-3 text-white">
                        Welcome, <strong>@Session["Username"]</strong> (@Session["Role"])
                    </span>
                    <a href="@Url.Action("Logout", "Login")" class="btn btn-outline-light btn-sm">Logout</a>
                }
                else
                {
                    <a href="@Url.Action("Index", "Login")" class="btn btn-outline-warning btn-sm">Login</a>
                }
            </div>
        </div>
    </nav>

    <!-- Main Body -->
    <div class="container mt-4">
        @RenderBody()
    </div>

    <!-- Footer -->
    <footer class="mt-auto">
        <div class="container">
            <p>&copy; @DateTime.Now.Year - LMS Lite | Developed by Ravindra Wadile</p>
        </div>
    </footer>

    <!-- Scripts -->
    <!-- Scripts via CDN -->
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.12/dist/jquery.validate.unobtrusive.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/popperjs/core@2.11.8/dist/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("scripts", required: false)


</body>
</html>
